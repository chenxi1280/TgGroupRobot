BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN

# PostgreSQL 数据库连接字符串
# 格式：postgresql+psycopg://用户名:密码@主机:端口/数据库名
# 注意：如果数据在 bot schema 下（而非默认的 public），代码会自动设置 search_path
# 示例（Docker / 线上基础设施网络）：
DATABASE_URL=postgresql+psycopg://app_user:replace_with_shared_app_password@postgres:5432/tggrouprobot
# 示例（本地环境）：
# DATABASE_URL=postgresql+psycopg://tg_bot:tg_bot@localhost:5432/tg_bot
DATABASE_CONNECT_TIMEOUT_SECONDS=10

LOG_LEVEL=INFO
LOG_FORMAT=console
APP_ENV=dev

# 启动优化：
# - 默认启动时会执行兼容性 schema 补丁并校验数据库结构。
#   线上结构稳定后可设为 false，只保留 schema gate 校验。
STARTUP_SCHEMA_MIGRATIONS_ENABLED=true
# - 默认不在 bot 刚开始 polling 前立刻跑所有后台任务。
SCHEDULER_RUN_IMMEDIATELY=false
SCHEDULER_INITIAL_STAGGER_SECONDS=0.25

# 可选：用于未来 webhook 模式（当前默认 long polling）
WEBHOOK_URL=

# Bot 全局管理员（逗号分隔 Telegram user_id）
# 例如：BOT_ADMIN_IDS=123456789,987654321
BOT_ADMIN_IDS=
INFRA_NETWORK_NAME=infra_default

# 用户功能手册站点映射到宿主机的端口
DOCS_SITE_HOST_PORT=8080
