BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN

# PostgreSQL 数据库连接字符串
# 格式：postgresql+psycopg://用户名:密码@主机:端口/数据库名
# 注意：如果数据在 bot schema 下（而非默认的 public），代码会自动设置 search_path
# 示例（Docker / 线上基础设施网络）：
DATABASE_URL=postgresql+psycopg://app_user:replace_with_shared_app_password@postgres:5432/tggrouprobot
# 示例（本地环境）：
# DATABASE_URL=postgresql+psycopg://tg_bot:tg_bot@localhost:5432/tg_bot
DATABASE_CONNECT_TIMEOUT_SECONDS=10

LOG_LEVEL=INFO
LOG_FORMAT=console
APP_ENV=dev

# 启动优化：
# - 默认启动时会执行兼容性 schema 补丁并校验数据库结构。
#   线上结构稳定后可设为 false，只保留 schema gate 校验。
STARTUP_SCHEMA_MIGRATIONS_ENABLED=true
# - 默认不在 bot 刚开始 polling 前立刻跑所有后台任务。
SCHEDULER_RUN_IMMEDIATELY=false
SCHEDULER_INITIAL_STAGGER_SECONDS=0.25

# 可选：用于未来 webhook 模式（当前默认 long polling）
WEBHOOK_URL=

# Bot 全局管理员（逗号分隔 Telegram user_id）
# 例如：BOT_ADMIN_IDS=123456789,987654321
BOT_ADMIN_IDS=
INFRA_NETWORK_NAME=infra_default

# 内置 Web 后台（首次启动会用下面的账号密码初始化超级管理员）
ADMIN_WEB_ENABLED=true
# 本地直接运行使用 127.0.0.1；生产 Docker 部署请在 /data/tggrouprobot/shared/.env
# 中改为 0.0.0.0，让 Docker 端口映射能访问容器内服务。
ADMIN_WEB_HOST=127.0.0.1
ADMIN_WEB_PORT=8088
# Docker 端口只发布到宿主机本地回环，再由宿主机 Nginx 的 /admin/ 反向代理访问；
# 不要把 ADMIN_WEB_PUBLISH_HOST 改成 0.0.0.0。
ADMIN_WEB_PUBLISH_HOST=127.0.0.1
ADMIN_SESSION_DAYS=7
ADMIN_BOOTSTRAP_USERNAME=admin
ADMIN_BOOTSTRAP_PASSWORD=change-me-please
ADMIN_BOOTSTRAP_DISPLAY_NAME=超级管理员

# GHCR 拉取凭证，生产服务器 shared .env 建议配置，便于发布和回滚拉取镜像。
GHCR_USERNAME=your_github_username
GHCR_TOKEN=ghp_replace_with_read_packages_token

# 用户手册静态文件由 docs-site 镜像释放到该目录，再由宿主机 Nginx 托管。
TGGROUPROBOT_DOCS_STATIC_BASE_DIR=/data/infra/www/robot.telema.cn
TGGROUPROBOT_WEB_HOST=robot.telema.cn
TGGROUPROBOT_CHECK_HOST_NGINX=1
# 默认不做公网 DNS 回环检查，避免服务器网络不支持 hairpin 时误报。
TGGROUPROBOT_CHECK_PUBLIC_URLS=0
TGGROUPROBOT_CHECK_ATTEMPTS=6
TGGROUPROBOT_CHECK_RETRY_DELAY_SECONDS=5
