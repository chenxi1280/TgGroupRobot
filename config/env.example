BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN

# PostgreSQL 数据库连接字符串
# 格式：postgresql+psycopg://用户名:密码@主机:端口/数据库名
# 注意：如果数据在 bot schema 下（而非默认的 public），代码会自动设置 search_path
# 示例（Docker 环境）：
DATABASE_URL=postgresql+psycopg://tg_bot:tg_bot@db:5432/tg_bot
# 示例（本地环境）：
# DATABASE_URL=postgresql+psycopg://tg_bot:tg_bot@localhost:5432/tg_bot

LOG_LEVEL=INFO
APP_ENV=dev

# 可选：用于未来 webhook 模式（当前默认 long polling）
WEBHOOK_URL=

# Bot 全局管理员（逗号分隔 Telegram user_id）
# 例如：BOT_ADMIN_IDS=123456789,987654321
BOT_ADMIN_IDS=



