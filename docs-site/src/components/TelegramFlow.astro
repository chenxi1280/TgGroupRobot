---
interface FlowButton {
  label: string;
  callbackData: string;
  action: 'goto' | 'back' | 'input' | 'toggle' | 'toast' | 'noop' | 'confirm' | 'external';
  target?: string;
  feedback?: string;
  highlight?: boolean;
}

interface FlowInputExample {
  label: string;
  value: string;
  feedback?: string;
  target?: string;
}

interface FlowInput {
  type: 'text' | 'media' | 'json' | 'buttons' | 'datetime' | 'number';
  prompt: string;
  placeholder?: string;
  clearCommand?: string;
  examples?: FlowInputExample[];
  errors?: string[];
}

interface FlowScreen {
  id: string;
  title: string;
  message: string[];
  stateLines?: string[];
  input?: FlowInput;
  keyboard: FlowButton[][];
}

interface FlowData {
  slug: string;
  title: string;
  coverage?: {
    mode?: string;
    alignmentStatus?: 'ok' | 'needsReview';
    alignmentSummary?: string;
    callbackPrefixes?: string[];
    inputStates?: string[];
    sourceFiles?: string[];
  };
  entryScreen: string;
  screens: FlowScreen[];
}

const { flow } = Astro.props as { flow: FlowData };
const initialScreen = flow.entryScreen || flow.screens[0]?.id;
const inputScreens = flow.screens.filter((screen) => screen.input);
const groupRuntimeScreens = flow.screens.filter((screen) =>
  screen.message.some((line) => /群内|成员|发送|触发|入群|开奖|发布/.test(line))
);
const sensitiveTokens = ['内定', '指定中奖', '预设中奖'];
const isSensitiveText = (value?: string) => sensitiveTokens.some((token) => String(value ?? '').includes(token));
const cleanManualText = (value?: string) => String(value ?? '')
  .replace('这里是后端进入私聊输入 state 后等待管理员发送内容的页面。', '请按照 Bot 提示在私聊发送内容。')
  .replace('Bot 处理真实回调后会重新渲染当前功能页或返回上一级。', '操作完成后，Bot 会刷新当前页面或返回上一级。')
  .replace(/，?最后确认内定中奖人后/g, '，最后确认发布后')
  .replace(/内定中奖人使用 Telegram 数字用户 ID/g, '按页面提示填写开奖参数')
  .replace(/内定中奖人/g, '开奖设置')
  .replace(/真实回调/g, '按钮操作')
  .replace(/后端/g, '系统');
const visibleMessage = (screen: FlowScreen) => screen.message
  .map(cleanManualText)
  .filter((line) => line && !line.startsWith('审计：'));
const visibleStateLines = (screen: FlowScreen) => (screen.stateLines ?? [])
  .map(cleanManualText)
  .filter((line) => line && !line.startsWith('审计：'));
const isSensitiveButton = (button: FlowButton) => isSensitiveText(button.label) || isSensitiveText(button.feedback);
const visibleRows = (screen: FlowScreen) => screen.keyboard
  .map((row) => row.filter((button) => !isSensitiveButton(button)))
  .filter((row) => row.length > 0);
const inputPrompt = (screen: FlowScreen) => cleanManualText(screen.input?.prompt);
const inputPlaceholder = (screen: FlowScreen) => cleanManualText(screen.input?.placeholder ?? '等待输入...');
const inputExamples = (screen: FlowScreen) => (screen.input?.examples ?? [])
  .filter((example) => !isSensitiveText(example.label) && !isSensitiveText(example.value) && !isSensitiveText(example.feedback))
  .map((example) => ({
    ...example,
    label: cleanManualText(example.label),
    value: cleanManualText(example.value),
    feedback: cleanManualText(example.feedback ?? `已填入示例：${example.label}`),
  }));
const toggleMark = (label: string) => {
  if (/^[✅☑️✓✔]/.test(label.trim())) return 'on';
  if (/^[❌✖×]/.test(label.trim())) return 'off';
  return /关闭|禁用|取消|删除|清空/.test(label) ? 'off' : 'on';
};
---

<section class="telegram-flow" data-telegram-flow aria-label={`${flow.title} Telegram 操作流`}>
  <div class="telegram-flow__head">
    <div>
      <p class="eyebrow">Telegram 操作流</p>
      <h2 id="telegram-flow">跟着真实按钮操作</h2>
    </div>
  </div>
  <div class="telegram-flow__coverage" aria-label="用户操作摘要">
    <span>入口：私聊 /start 后点击「{flow.title}」</span>
    <span>页面：{flow.screens.length} 个</span>
    <span>输入：{inputScreens.length ? `${inputScreens.length} 处需要填写` : '全程按钮操作'}</span>
    <span>群内：{groupRuntimeScreens.length ? '需要回到群内验证效果' : '主要在私聊完成配置'}</span>
  </div>

  <div class="telegram-flow__stage">
    {flow.screens.map((screen, index) => (
      <article
        class:list={['telegram-flow-screen', screen.id === initialScreen && 'is-active']}
        data-flow-screen={screen.id}
      >
        <div class="telegram-screen" aria-label={`${flow.title}: ${screen.title}`}>
          <div class="telegram-screen-progress">第 {index + 1} / {flow.screens.length} 页</div>
          <div class="telegram-message">
            <div class="bot-name">@TgGroupRobot</div>
            <div class="message-title">{screen.title}</div>
            {visibleMessage(screen).map((line) => <p>{line}</p>)}
            {visibleStateLines(screen).length > 0 && (
              <div class="state-lines">
                {visibleStateLines(screen).map((line) => <span>{line}</span>)}
              </div>
            )}
            {screen.input && (
              <div class="telegram-input-block" data-input-block>
                <strong>{inputPrompt(screen)}</strong>
                <div class="telegram-input-box" data-input-value>
                  {inputPlaceholder(screen)}
                </div>
                {screen.input.clearCommand && (
                  <p class="tip">清空方式：{screen.input.clearCommand}</p>
                )}
                {inputExamples(screen).length > 0 && (
                  <div class="telegram-input-examples">
                    {inputExamples(screen).map((example) => (
                      <button
                        type="button"
                        data-input-example={example.value}
                        data-flow-target={example.target}
                        data-feedback={example.feedback ?? `已填入示例：${example.label}`}
                      >
                        {example.label}
                      </button>
                    ))}
                  </div>
                )}
                {screen.input.errors && screen.input.errors.length > 0 && (
                  <ul class="telegram-input-errors">
                    {screen.input.errors.map((error) => <li>{error}</li>)}
                  </ul>
                )}
              </div>
            )}
            <span class="message-time">13:41</span>
          </div>

          <div class="telegram-keyboard">
            {visibleRows(screen).map((row) => (
              <div class="keyboard-row" style={`--keyboard-columns: ${row.length}`}>
                {row.map((button) => (
                  <button
                    type="button"
                    class:list={['keyboard-button', button.highlight && 'is-highlighted']}
                    data-flow-action={button.action}
                    data-flow-target={button.target}
                    data-feedback={button.feedback}
                    aria-pressed={button.action === 'toggle' ? 'false' : undefined}
                    title={button.feedback ?? button.label}
                  >
                    <span class="keyboard-button__label">
                      {button.action === 'toggle' && (
                        <span
                          class:list={['keyboard-button__toggle-mark', toggleMark(button.label) === 'off' && 'is-off']}
                          data-toggle-mark={toggleMark(button.label)}
                          aria-hidden="true"
                        >
                          {toggleMark(button.label) === 'off' ? '×' : '✓'}
                        </span>
                      )}
                      <span>{button.label}</span>
                    </span>
                  </button>
                ))}
              </div>
            ))}
          </div>
        </div>
      </article>
    ))}
  </div>

  <p class="telegram-feedback" data-flow-feedback aria-live="polite">
    点击上方 Telegram 按钮开始；手机端按页面顺序往下点即可。
  </p>
</section>

<script>
  for (const root of document.querySelectorAll('[data-telegram-flow]')) {
    const screens = Array.from(root.querySelectorAll('[data-flow-screen]'));
    const feedback = root.querySelector('[data-flow-feedback]');
    let active = screens.find((screen) => screen.classList.contains('is-active'))?.getAttribute('data-flow-screen') ?? '';

    const setFeedback = (message: string) => {
      if (feedback) feedback.textContent = message;
    };

    const show = (screenId: string, message?: string) => {
      if (!screenId || !screens.some((screen) => screen.getAttribute('data-flow-screen') === screenId)) {
        setFeedback(message ?? '这个按钮当前停留在本页。');
        return;
      }
      active = screenId;
      screens.forEach((screen) => {
        screen.classList.toggle('is-active', screen.getAttribute('data-flow-screen') === active);
      });
      if (message) setFeedback(message);
      if (root instanceof HTMLElement) root.scrollIntoView({ behavior: 'smooth', block: 'start' });
    };

    const pulse = (button: Element) => {
      button.classList.add('is-pressed');
      window.setTimeout(() => button.classList.remove('is-pressed'), 180);
    };

    const toggleSwitch = (button: Element, message: string) => {
      const mark = button.querySelector('[data-toggle-mark]');
      if (mark) {
        const nextState = mark.getAttribute('data-toggle-mark') === 'on' ? 'off' : 'on';
        mark.setAttribute('data-toggle-mark', nextState);
        mark.textContent = nextState === 'on' ? '✓' : '×';
        mark.classList.toggle('is-off', nextState === 'off');
      }
      const nextPressed = button.getAttribute('aria-pressed') !== 'true';
      button.setAttribute('aria-pressed', String(nextPressed));
      button.classList.toggle('is-toggled', nextPressed);
      setFeedback(message || '设置已切换，Bot 会刷新当前页面。');
    };

    root.querySelectorAll('[data-flow-action]').forEach((button) => {
      button.addEventListener('click', () => {
        const action = button.getAttribute('data-flow-action');
        const target = button.getAttribute('data-flow-target') ?? '';
        const message = button.getAttribute('data-feedback') ?? '已点击。';
        pulse(button);

        if (action === 'toggle') {
          toggleSwitch(button, message);
          return;
        }
        if (['goto', 'back', 'input', 'confirm'].includes(action ?? '')) {
          show(target || active, message);
          return;
        }
        if (action === 'external') {
          setFeedback(message || '这是外部链接按钮。');
          return;
        }
        setFeedback(message);
      });
    });

    root.querySelectorAll('[data-input-example]').forEach((button) => {
      button.addEventListener('click', () => {
        const value = button.getAttribute('data-input-example') ?? '';
        const message = button.getAttribute('data-feedback') ?? '已填入示例。';
        const target = button.getAttribute('data-flow-target') ?? '';
        const screen = button.closest('[data-flow-screen]');
        const valueBox = screen?.querySelector('[data-input-value]');
        if (valueBox) valueBox.textContent = value;
        pulse(button);
        if (target) {
          window.setTimeout(() => show(target, message), 180);
          return;
        }
        setFeedback(message);
      });
    });
  }
</script>
