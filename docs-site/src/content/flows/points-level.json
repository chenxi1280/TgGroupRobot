            "highlight": true
          }
        ],
        [
          {
            "label": "切换群",
            "callbackData": "adm:switch_group",
            "action": "goto",
            "target": "select_group",
            "feedback": "进入群组选择。"
          },
          {
            "label": "返回主菜单",
            "callbackData": "adm:menu:main:{chat_id}",
            "action": "goto",
            "target": "main_menu",
            "feedback": "已回到主菜单。"
          }
        ]
      ],
      "stateLines": [
        "当前群组：演示群"
      ]
    },
    {
      "id": "select_group",
      "title": "选择配置群组",
      "message": [
        "私聊配置前先确认目标群组，后续按钮都会写入这个群。"
      ],
      "keyboard": [
        [
          {
            "label": "演示群",
            "callbackData": "adm:select_group:-1001001",
            "action": "goto",
            "target": "entry",
            "feedback": "已切换到演示群。"
          },
          {
            "label": "测试群",
            "callbackData": "adm:select_group:-1001002",
