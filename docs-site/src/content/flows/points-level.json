            "feedback": "已切换到测试群。"
          }
        ],
        [
          {
            "label": "返回",
            "callbackData": "adm:menu:points_level:{chat_id}",
            "action": "back",
            "target": "entry",
            "feedback": "已返回。"
          }
        ]
      ],
      "stateLines": [
        "可管理群：演示群、测试群"
      ]
    },
    {
      "id": "main_menu",
      "title": "主菜单",
      "message": [
        "这里展示机器人后台的真实功能入口。"
      ],
      "keyboard": [
        [
          {
            "label": "积分等级",
            "callbackData": "adm:menu:points_level:{chat_id}",
            "action": "goto",
            "target": "home",
            "feedback": "已进入「积分等级」。",
            "highlight": true
          }
        ]
      ]
    },
    {
      "id": "home",
      "title": "积分等级",
      "message": [
        "配置积分等级门槛和等级权限。"
      ],
      "keyboard": [
        [
          {
            "label": "新增等级",
            "callbackData": "adm:lvl:{chat_id}:add",
            "action": "input",
            "target": "level_name_input",
            "feedback": "请输入等级名称。",
            "highlight": true
          },
          {
            "label": "开启等级",
            "callbackData": "adm:lvl:{chat_id}:toggle:enabled:1",
            "action": "toggle",
            "target": "home",
            "feedback": "积分等级已开启。"
          },
          {
            "label": "关闭等级",
            "callbackData": "adm:lvl:{chat_id}:toggle:enabled:0",
            "action": "toggle",
            "target": "home",
            "feedback": "积分等级已关闭。"
          }
        ],
        [
          {
            "label": "等级详情",
            "callbackData": "adm:lvl:{chat_id}:detail:{level_id}",
            "action": "goto",
            "target": "detail",
            "feedback": "已打开等级详情。"
          }
        ],
        [
          {
            "label": "返回主菜单",
            "callbackData": "adm:menu:main:{chat_id}",
            "action": "back",
            "target": "entry",
            "feedback": "已返回主菜单。"
          }
        ]
      ],
      "stateLines": [
        "当前群组：演示群"
      ]
    },
    {
      "id": "detail",
      "title": "等级详情",
      "message": [
        "详情页可以编辑名称、门槛、权限和删除等级。"
      ],
      "keyboard": [
        [
          {
            "label": "编辑名称",
            "callbackData": "adm:lvl:{chat_id}:edit:name:{level_id}",
            "action": "input",
            "target": "level_name_input",
            "feedback": "请输入等级名称。"
          },
          {
            "label": "编辑门槛",
            "callbackData": "adm:lvl:{chat_id}:edit:threshold:{level_id}",
            "action": "input",
            "target": "threshold_input",
            "feedback": "请输入积分门槛。"
          }
        ],
        [
          {
            "label": "允许发言",
            "callbackData": "adm:lvl:{chat_id}:perm:{level_id}:allow_text:1",
            "action": "toggle",
            "target": "detail",
            "feedback": "等级发言权限已开启。"
          },
          {
            "label": "删除确认",
            "callbackData": "adm:lvl:{chat_id}:delete_confirm:{level_id}",
            "action": "confirm",
            "target": "delete_confirm",
            "feedback": "请确认删除。"
          }
        ],
        [
          {
            "label": "返回等级列表",
            "callbackData": "adm:menu:points_level:{chat_id}",
            "action": "back",
            "target": "home",
            "feedback": "已返回等级列表。"
          }
        ]
      ]
    },
    {
      "id": "level_name_input",
      "title": "输入等级名称",
      "message": [
        "这里是后端进入私聊输入 state 后等待管理员发送内容的页面。"
      ],
      "keyboard": [
        [
          {
            "label": "返回",
            "callbackData": "adm:menu:points_level:{chat_id}",
            "action": "back",
            "target": "home",
            "feedback": "已返回上一层。"
          }
        ]
      ],
      "input": {
        "type": "text",
        "prompt": "发送等级名称",
        "placeholder": "Lv1",
        "clearCommand": "/clear",
        "examples": [
          {
            "label": "等级名称",
            "value": "Lv1",
            "target": "result",
            "feedback": "已填入：等级名称。"
          }
        ],
        "errors": [
          "格式不符合要求时，Bot 会停留在输入态并提示重新输入。"
        ]
      }
    },
    {
      "id": "threshold_input",
      "title": "输入等级门槛",
      "message": [
        "这里是后端进入私聊输入 state 后等待管理员发送内容的页面。"
      ],
      "keyboard": [
        [
          {
            "label": "返回",
            "callbackData": "adm:lvl:{chat_id}:detail:{level_id}",
            "action": "back",
            "target": "detail",
            "feedback": "已返回上一层。"
          }
        ]
      ],
      "input": {
        "type": "text",
        "prompt": "发送整数积分",
        "placeholder": "100",
        "examples": [
          {
            "label": "100 分",
            "value": "100",
            "target": "result",
            "feedback": "已填入：100 分。"
          }
        ],
        "errors": [
          "格式不符合要求时，Bot 会停留在输入态并提示重新输入。"
        ]
      }
    },
    {
      "id": "delete_confirm",
      "title": "删除确认",
      "message": [
        "删除等级后不会删除用户积分。"
      ],
      "keyboard": [
        [
          {
            "label": "确认删除",
            "callbackData": "adm:lvl:{chat_id}:delete:{level_id}",
            "action": "confirm",
            "target": "result",
            "feedback": "已删除等级。"
          },
          {
            "label": "返回详情",
            "callbackData": "adm:lvl:{chat_id}:detail:{level_id}",
            "action": "back",
            "target": "detail",
            "feedback": "已取消。"
          }
        ]
      ]
    },
    {
      "id": "result",
      "title": "设置结果",
      "message": [
        "Bot 保存配置后会重新渲染当前功能页。",
        "请在群内用测试账号触发一次，确认权限和运行结果。"
      ],
      "keyboard": [
        [
          {
            "label": "返回设置页",
            "callbackData": "adm:menu:points_level:{chat_id}",
            "action": "back",
            "target": "home",
            "feedback": "已返回设置页。"
          }
        ]
      ],
      "stateLines": [
        "审计：回调来自后端真实路由"
      ]
    }
  ]
}
