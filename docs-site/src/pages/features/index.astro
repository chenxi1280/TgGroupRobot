---
import SiteLayout from '../../components/SiteLayout.astro';
import FeatureIndex from '../../components/FeatureIndex.astro';

const page = {
  title: '功能总览',
  description: 'TgGroupRobot 各项群组管理功能的使用说明入口。'
};
---

<SiteLayout title={`${page.title} - TgGroupRobot 功能手册`} description={page.description}>
  <header class="page-heading">
    <p class="eyebrow">功能总览</p>
    <h1>所有功能</h1>
    <p>按产品模块浏览功能页。每一页都包含配置步骤、仿 Telegram 操作图和常见问题。</p>
  </header>
  <FeatureIndex />
</SiteLayout>
